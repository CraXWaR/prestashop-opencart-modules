{{ header }}{{ column_left }}
<div id="content">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <button type="button" form="form-conversion-boost" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
                <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
            </div>
            <h1>{{ heading_title }}</h1>
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>
    <div class="container-fluid">
        <div class="panel panel-default">
            <div class="panel-body">
                <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-conversion-boost" class="form-horizontal">

                    <div class="form-group">
                        <label class="col-sm-2 control-label">{{ entry_status }}</label>
                        <div class="col-sm-10">
                            <select name="module_conversion_boost_status" class="form-control">
                                <option value="1" {% if status == '1' %}selected{% endif %}>{{ text_enable }}</option>
                                <option value="0" {% if status == '0' %}selected{% endif %}>{{ text_disable }}</option>
                            </select>
                        </div>
                    </div>

                    <hr>
                    <h3>{{ text_sticky_settings }}</h3>

                    <div class="form-group">
                        <label class="col-sm-2 control-label">{{ entry_sticky_position }}</label>
                        <div class="col-sm-10">
                            <select name="module_conversion_boost_sticky_position" class="form-control">
                                <option value="top" {% if sticky_position == 'top' %}selected{% endif %}>{{ text_top }}</option>
                                <option value="bottom" {% if sticky_position == 'bottom' %}selected{% endif %}>{{ text_bottom }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-2 control-label">{{ entry_sticky_bg_color }}</label>
                        <div class="col-sm-10">
                            <input type="color" name="module_conversion_boost_sticky_bg_color" value="{{ sticky_bg_color }}" class="form-control">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-2 control-label">{{ entry_sticky_btn_color }}</label>
                        <div class="col-sm-10">
                            <input type="color" name="module_conversion_boost_sticky_btn_color" value="{{ sticky_btn_color }}" class="form-control">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-2 control-label">{{ entry_sticky_hide_mobile }}</label>
                        <div class="col-sm-10">
                            <select name="module_conversion_boost_sticky_hide_mobile" class="form-control">
                                <option value="1" {% if sticky_hide_mobile == '1' %}selected{% endif %}>{{ text_yes }}</option>
                                <option value="0" {% if sticky_hide_mobile == '0' %}selected{% endif %}>{{ text_no }}</option>
                            </select>
                        </div>
                    </div>

                    <hr>
                    <h3>{{ text_timer_settings }}</h3>

                    <div class="form-group">
                        <label class="col-sm-2 control-label">{{ entry_timer_style }}</label>
                        <div class="col-sm-10">
                            <select name="module_conversion_boost_timer_style" class="form-control">
                                <option value="plain" {% if timer_style == 'plain' %}selected{% endif %}>{{ text_plain }}</option>
                                <option value="flip" {% if timer_style == 'flip' %}selected{% endif %}>{{ text_flip }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-2 control-label">{{ entry_timer_accent_color }}</label>
                        <div class="col-sm-10">
                            <input type="color" name="module_conversion_boost_timer_accent_color" value="{{ timer_accent_color }}" class="form-control">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-2 control-label">{{ entry_timer_text }}</label>
                        <div class="col-sm-10">
                            <input type="text" name="module_conversion_boost_timer_text" value="{{ timer_text }}" class="form-control">
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{{ footer }}