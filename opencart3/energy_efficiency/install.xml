    </file>

    <file path="catalog/view/theme/default/template/common/header.twig">
        <operation>
            <search><![CDATA[</head>]]></search>
            <add position="before"><![CDATA[
{% if custom_css is defined and custom_css %}
<style>{{ custom_css }}</style>
{% endif %}
        ]]></add>
        </operation>
    </file>

</modification>