{{ header }}{{ column_left }}
<div id="content">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <button type="submit"
                        form="form-energy-label"
                        name="stay"
                        value="1"
                        class="btn btn-success">
                    <i class="fa fa-save"></i> {{ button_save_stay }}
                </button>

                <button type="submit"
                        form="form-energy-label"
                        class="btn btn-primary">
                    <i class="fa fa-save"></i> {{ button_save }}
                </button>

                <a href="{{ cancel }}" class="btn btn-default">
                    <i class="fa fa-reply"></i> {{ button_cancel }}
                </a>

            </div>

            <h1>{{ heading_title }}</h1>

            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="container-fluid">
        {% if success %}
            <div class="alert alert-success alert-dismissible">
                <i class="fa fa-check-circle"></i> {{ success }}
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        {% endif %}

        {% if error_warning %}
            <div class="alert alert-danger alert-dismissible">
                <i class="fa fa-exclamation-circle"></i> {{ error_warning }}
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        {% endif %}

        {% if error_icon %}
            <div class="alert alert-danger alert-dismissible">
                <i class="fa fa-exclamation-circle"></i> {{ error_icon }}
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        {% endif %}

        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-bolt"></i> {{ text_edit }}</h3>
            </div>
            <div class="panel-body">

                <ul class="nav nav-tabs">
                    <li class="active"><a href="#tab-settings" data-toggle="tab">{{ tab_settings }}</a></li>
                    <li><a href="#tab-classes" data-toggle="tab">{{ tab_classes }}</a></li>
                    <li><a href="#tab-bulk" data-toggle="tab">{{ tab_bulk }}</a></li>
                </ul>

                <form id="form-energy-label" action="{{ action }}" method="post" enctype="multipart/form-data">
                    <div class="tab-content">
                        <div class="tab-pane active" id="tab-settings">
                            <div class="form-horizontal">
                                <div class="form-group">
                                    <label class="col-sm-2 control-label">{{ label_status }}</label>
                                    <div class="col-sm-10">
                                        <select name="module_energy_label_status" class="form-control">
                                            <option value="1"
                                                    {% if module_energy_label_status == '1' %}selected{% endif %}>
                                                {{ text_enabled }}
                                            </option>

                                            <option value="0"
                                                    {% if module_energy_label_status != '1' %}selected{% endif %}>
                                                {{ text_disabled }}
                                            </option>
                                        </select>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label class="col-sm-2 control-label">{{ label_show_product }}</label>
                                    <div class="col-sm-10">
                                        <select name="module_energy_label_show_product" class="form-control">
                                            <option value="1"
                                                    {% if module_energy_label_show_product == '1' %}selected{% endif %}>
                                                {{ text_yes }}
                                            </option>

                                            <option value="0"
                                                    {% if module_energy_label_show_product != '1' %}selected{% endif %}>
                                                {{ text_no }}
                                            </option>
                                        </select>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label class="col-sm-2 control-label">{{ label_show_category }}</label>
                                    <div class="col-sm-10">
                                        <select name="module_energy_label_show_category" class="form-control">
                                            <option value="1"
                                                    {% if module_energy_label_show_category == '1' %}selected{% endif %}>
                                                {{ text_yes }}
                                            </option>

                                            <option value="0"
                                                    {% if module_energy_label_show_category != '1' %}selected{% endif %}>
                                                {{ text_no }}
                                            </option>
                                        </select>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label class="col-sm-2 control-label">{{ label_custom_css }}</label>
                                    <div class="col-sm-10">
                                        <textarea name="module_energy_label_custom_css"
                                                  class="form-control"
                                                  rows="8"
                                                  placeholder=".energy-label-block { }">{{ module_energy_label_custom_css }}</textarea>

                                        <span class="help-block">{{ help_custom_css }}</span>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label class="col-sm-2 control-label">{{ label_show_search }}</label>
                                    <div class="col-sm-10">
                                        <select name="module_energy_label_show_search" class="form-control">
                                            <option value="1" {% if module_energy_label_show_search == '1' %}selected{% endif %}>{{ text_yes }}</option>
                                            <option value="0" {% if module_energy_label_show_search != '1' %}selected{% endif %}>{{ text_no }}</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label class="col-sm-2 control-label">{{ label_show_special }}</label>
                                    <div class="col-sm-10">
                                        <select name="module_energy_label_show_special" class="form-control">
                                            <option value="1" {% if module_energy_label_show_special == '1' %}selected{% endif %}>{{ text_yes }}</option>
                                            <option value="0" {% if module_energy_label_show_special != '1' %}selected{% endif %}>{{ text_no }}</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label class="col-sm-2 control-label">{{ label_show_manufacturer }}</label>
                                    <div class="col-sm-10">
                                        <select name="module_energy_label_show_manufacturer" class="form-control">
                                            <option value="1" {% if module_energy_label_show_manufacturer == '1' %}selected{% endif %}>{{ text_yes }}</option>
                                            <option value="0" {% if module_energy_label_show_manufacturer != '1' %}selected{% endif %}>{{ text_no }}</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label class="col-sm-2 control-label">{{ label_show_journal3 }}</label>
                                    <div class="col-sm-10">
                                        <select name="module_energy_label_show_journal3" class="form-control">
                                            <option value="1" {% if module_energy_label_show_journal3 == '1' %}selected{% endif %}>{{ text_yes }}</option>
                                            <option value="0" {% if module_energy_label_show_journal3 != '1' %}selected{% endif %}>{{ text_no }}</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane" id="tab-classes">
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover" id="energy-class-table">
                                    <thead>
                                    <tr>
                                        <th>{{ column_class_name }}</th>
                                        <th>{{ column_class_icon }}</th>
                                        <th class="text-center col-sort">{{ column_sort_order }}</th>
                                        <th class="text-right col-action">{{ column_action }}</th>
                                    </tr>
                                    </thead>

                                    <tbody id="class-rows">
                                    {% for class in energy_classes %}
                                        <tr id="class-row-{{ class.energy_class_id }}">
                                            <td>
                                                <input type="hidden"
                                                       name="energy_classes[{{ class.energy_class_id }}][energy_class_id]"
                                                       value="{{ class.energy_class_id }}">
                                                <input type="text"
                                                       name="energy_classes[{{ class.energy_class_id }}][name]"
                                                       class="form-control class-name-input"
                                                       value="{{ class.name }}"
                                                       maxlength="20">
                                            </td>

                                            <td>
                                                <div class="class-icon-input">
                                                    <a href=""
                                                       id="thumb-class-{{ class.energy_class_id }}"
                                                       data-toggle="image"
                                                       class="img-thumbnail">
                                                        <img src="{{ class.thumb }}"
                                                             data-placeholder="{{ placeholder }}"
                                                             alt="" class="el-class-icon-img">
                                                    </a>
                                                    <input type="hidden"
                                                           name="energy_classes[{{ class.energy_class_id }}][icon]"
                                                           id="input-class-{{ class.energy_class_id }}"
                                                           class="icon-path"
                                                           value="{{ class.icon }}">
                                                </div>
                                            </td>

                                            <td class="text-center">
                                                <input type="number"
                                                       name="energy_classes[{{ class.energy_class_id }}][sort_order]"
                                                       class="form-control class-sort-input text-center"
                                                       value="{{ class.sort_order }}"
                                                       min="0">
                                            </td>

                                            <td class="text-right">
                                                <button type="button"
                                                        class="btn btn-danger btn-xs btn-delete-class"
                                                        data-id="{{ class.energy_class_id }}">

                                                    <i class="fa fa-trash-o"></i>
                                                    {{ button_delete }}
                                                </button>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>

                            <button type="button" class="btn btn-success" id="btn-add-class">
                                <i class="fa fa-plus-circle"></i>
                                {{ button_add_class }}
                            </button>
                        </div>

                        <div class="tab-pane" id="tab-bulk">
                            <div class="form-horizontal" style="margin-top: 20px;">

                                {# ---- Export ---- #}
                                <div class="form-group">
                                    <label class="col-sm-2 control-label">{{ label_export }}</label>
                                    <div class="col-sm-10">
                                        <a href="{{ export_url }}" class="btn btn-success">
                                            <i class="fa fa-download"></i> {{ button_export }}
                                        </a>
                                        <span class="help-block">{{ help_export }}</span>
                                    </div>
                                </div>

                                <hr>

                                {# ---- Import ---- #}
                                <div class="form-group">
                                    <label class="col-sm-2 control-label">{{ label_import }}</label>
                                    <div class="col-sm-10">

                                        <div style="margin-bottom: 8px;">
                                            <label style="font-weight: normal; margin-bottom: 4px; display:block;">
                                                <i class="fa fa-file-excel-o"></i> {{ label_import_excel }}
                                            </label>
                                            <input type="file" id="import-file" accept=".xlsx,.csv" class="form-control"
                                                   style="max-width: 500px;">
                                        </div>

                                        <div style="margin-bottom: 8px;">
                                            <label style="font-weight: normal; margin-bottom: 4px; display:block;">
                                                <i class="fa fa-file-zip-o"></i> {{ label_import_zip }}
                                            </label>
                                            <input type="file" id="import-zip" accept=".zip" class="form-control"
                                                   style="max-width: 500px;">
                                            <span class="help-block">{{ help_import_zip }}</span>
                                        </div>

                                        <button type="button" id="btn-import" class="btn btn-primary">
                                            <i class="fa fa-upload"></i> {{ button_import }}
                                        </button>

                                        <span class="help-block">{{ help_import }}</span>

                                        <div id="import-progress" style="display:none; margin-top: 10px;">
                                            <i class="fa fa-spinner fa-spin"></i> {{ text_importing }}
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    (function () {
        'use strict';

        var urlImport = '{{ import_url }}'.replace(/&amp;/g, '&');

        // Remember active tab
        $('a[data-toggle="tab"]').on('shown.bs.tab', function (e) {
            localStorage.setItem('energyLabelActiveTab', $(e.target).attr('href'));
        });
        var savedTab = localStorage.getItem('energyLabelActiveTab');
        if (savedTab) {
            $('.nav-tabs a[href="' + savedTab + '"]').tab('show');
        }

        // ---- Delete class (existing logic) -----------------------------------
        var urlDeleteClass = '{{ delete_class }}'.replace(/&amp;/g, '&');

        $(document).on('click', '.btn-delete-class', function () {
            if (!confirm('{{ button_delete }}?')) return;
            var $btn = $(this);
            var id = $btn.data('id');
            $btn.prop('disabled', true);
            $.ajax({
                url: urlDeleteClass, type: 'POST',
                data: {energy_class_id: id}, dataType: 'json',
                success: function (json) {
                    if (json.error) {
                        showAlert('danger', json.error);
                    } else {
                        showAlert('success', json.success);
                        $('#class-row-' + id).fadeOut(300, function () {
                            $(this).remove();
                        });
                    }
                },
                error: function () {
                    showAlert('danger', 'Server error. Please try again.');
                },
                complete: function () {
                    $btn.prop('disabled', false);
                }
            });
        });

        // ---- Add new class row (existing logic) ------------------------------
        var classRow = {{ energy_classes|length }};

        $('#btn-add-class').on('click', function () {
            var rowId = 'new-' + classRow;
            var html = '<tr id="class-row-' + rowId + '">';
            html += '<input type="hidden" name="energy_classes[' + classRow + '][energy_class_id]" value="0">';
            html += '<td><input type="text" name="energy_classes[' + classRow + '][name]" class="form-control class-name-input" value="" maxlength="20"></td>';
            html += '<td><div class="class-icon-input">';
            html += '<a href="" id="thumb-class-' + rowId + '" data-toggle="image" class="img-thumbnail">';
            html += '<img src="{{ placeholder }}" data-placeholder="{{ placeholder }}" alt="" class="el-class-icon-img"></a>';
            html += '<input type="hidden" name="energy_classes[' + classRow + '][icon]" id="input-class-' + rowId + '" class="icon-path" value=""></div></td>';
            html += '<td class="text-center"><input type="number" name="energy_classes[' + classRow + '][sort_order]" class="form-control class-sort-input text-center" value="0" min="0"></td>';
            html += '<td class="text-right"><button type="button" class="btn btn-danger btn-xs btn-remove-new"><i class="fa fa-trash-o"></i> {{ button_delete }}</button></td>';
            html += '</tr>';
            $('#class-rows').append(html);
            classRow++;
        });

        $(document).on('click', '.btn-remove-new', function () {
            $(this).closest('tr').remove();
        });

        // ---- Import handler --------------------------------------------------
        $('#btn-import').on('click', function () {
            var fileInput = document.getElementById('import-file');
            var zipInput = document.getElementById('import-zip');

            if (!fileInput.files.length) {
                showBulkAlert('danger', '{{ text_no_file_selected }}');
                return;
            }

            var file = fileInput.files[0];
            var ext = file.name.split('.').pop().toLowerCase();
            if (ext !== 'xlsx' && ext !== 'csv') {
                showBulkAlert('danger', '{{ error_import_file_type }}');
                return;
            }

            if (zipInput.files.length) {
                var zipExt = zipInput.files[0].name.split('.').pop().toLowerCase();
                if (zipExt !== 'zip') {
                    showBulkAlert('danger', '{{ error_import_zip_type }}');
                    return;
                }
            }

            var formData = new FormData();
            formData.append('import_file', file);
            if (zipInput.files.length) {
                formData.append('import_zip', zipInput.files[0]);
            }

            $('#import-progress').show();
            $('#btn-import').prop('disabled', true);

            $.ajax({
                url: urlImport, type: 'POST',
                data: formData, dataType: 'json',
                contentType: false, processData: false,
                success: function (json) {
                    if (json.error) {
                        showBulkAlert('danger', json.error);
                    } else {
                        showBulkAlert('success', json.success);
                        fileInput.value = '';
                        zipInput.value = '';
                    }
                },
                error: function () {
                    showBulkAlert('danger', 'Server error. Please try again.');
                },
                complete: function () {
                    $('#import-progress').hide();
                    $('#btn-import').prop('disabled', false);
                }
            });
        });

        // ---- Alert helpers ---------------------------------------------------
        function showAlert(type, msg) {
            $('#class-alert').remove();
            var html = '<div id="class-alert" class="alert alert-' + type + ' alert-dismissible">';
            html += '<button type="button" class="close" data-dismiss="alert">&times;</button>' + msg + '</div>';
            $('.panel-body').prepend(html);
            $('html, body').animate({scrollTop: $('#class-alert').offset().top - 80}, 300);
        }

        function showBulkAlert(type, msg) {
            $('#bulk-alert').remove();
            var html = '<div id="bulk-alert" class="alert alert-' + type + ' alert-dismissible">';
            html += '<button type="button" class="close" data-dismiss="alert">&times;</button>' + msg + '</div>';
            $('#tab-bulk').prepend(html);
            $('html, body').animate({scrollTop: $('#bulk-alert').offset().top - 80}, 300);
        }

    })();
</script>
{{ footer }}
