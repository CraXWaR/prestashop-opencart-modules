{% if reviews %}
    <section class="google-reviews-section" style="background:{{ bg_color }};">
        <div class="gr-section-title">
            <h3 style="color:{{ text_color }};">{{ heading_title }}</h3>
        </div>
        {% if enable_slider %}
            <div class="swiper gr-swiper">
                <div class="swiper-wrapper">
                    {% for review in reviews %}
                        <div class="swiper-slide">
                            <div class="gr-card" style="background:{{ card_bg_color }};">
                                <div class="gr-card-header">
                                    <div class="gr-author">
                                        {% if review.author_avatar %}
                                            <img src="{{ review.author_avatar }}" alt="{{ review.author_name }}"
                                                 class="gr-avatar-img">
                                        {% else %}
                                            <div class="gr-avatar-letter">
                                                {{ review.author_name|first|upper }}
                                            </div>
                                        {% endif %}
                                        <div class="gr-author-info">
                                            <strong class="gr-author-name"
                                                    style="color:{{ text_color }};">{{ review.author_name|upper }}</strong>
                                            {% if show_date and review.review_date %}
                                                <span class="gr-date">{{ review.review_date|date('d.m.Y') }}</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                    {% if show_logo %}
                                        <div class="gr-google-icon">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="32"
                                                 height="32">
                                                <path fill="#EA4335"
                                                      d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                                <path fill="#4285F4"
                                                      d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                                <path fill="#FBBC05"
                                                      d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                                <path fill="#34A853"
                                                      d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                                                <path fill="none" d="M0 0h48v48H0z"/>
                                            </svg>
                                        </div>
                                    {% endif %}
                                </div>

                                <div class="gr-stars">
                                    {% for i in 1..5 %}
                                        <span class="gr-star {% if i <= review.rating %}gr-star--filled{% endif %}"
                                              style="color:{{ accent_color }};">★</span>
                                    {% endfor %}
                                </div>

                                <div class="gr-review-text" style="color:{{ text_color }};">
                                    {{ review.review_text|length > 120 ? review.review_text|slice(0, 120) ~ '...' : review.review_text }}
                                </div>

                                {% if review.review_text|length > 100 %}
                                    <a href="#" class="gr-read-more"
                                       style="color:{{ accent_color }};"
                                       data-full="{{ review.review_text|e('html_attr') }}">
                                        {{ text_read_more }}
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% else %}

            <div class="gr-grid gr-cols-{{ per_row }}">
                {% for review in reviews %}
                    <div class="gr-card" style="background:{{ card_bg_color }};">

                        <div class="gr-card-header">
                            <div class="gr-author">
                                {% if review.author_avatar %}
                                    <img src="{{ review.author_avatar }}" alt="{{ review.author_name }}"
                                         class="gr-avatar-img">
                                {% else %}
                                    <div class="gr-avatar-letter">
                                        {{ review.author_name|first|upper }}
                                    </div>
                                {% endif %}
                                <div class="gr-author-info">
                                    <strong class="gr-author-name"
                                            style="color:{{ text_color }};">{{ review.author_name|upper }}</strong>
                                    {% if show_date and review.review_date %}
                                        <span class="gr-date">{{ review.review_date|date('d.m.Y') }}</span>
                                    {% endif %}
                                </div>
                            </div>
                            {% if show_logo %}
                                <div class="gr-google-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="32"
                                         height="32">
                                        <path fill="#EA4335"
                                              d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                        <path fill="#4285F4"
                                              d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                        <path fill="#FBBC05"
                                              d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                        <path fill="#34A853"
                                              d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                                        <path fill="none" d="M0 0h48v48H0z"/>
                                    </svg>
                                </div>
                            {% endif %}
                        </div>

                        <div class="gr-stars">
                            {% for i in 1..5 %}
                                <span class="gr-star {% if i <= review.rating %}gr-star--filled{% endif %}"
                                      style="color:{{ accent_color }};">★</span>
                            {% endfor %}
                        </div>

                        <div class="gr-review-text" style="color:{{ text_color }};">
                            {{ review.review_text|length > 100 ? review.review_text|slice(0, 100) ~ '...' : review.review_text }}
                        </div>

                        {% if review.review_text|length > 100 %}
                            <a href="#" class="gr-read-more"
                               style="color:{{ accent_color }};"
                               data-full="{{ review.review_text|e('html_attr') }}">
                                {{ text_read_more }}
                            </a>
                        {% endif %}

                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </section>

    <div id="gr-modal" class="gr-modal">
        <div class="gr-modal-overlay"></div>
        <div class="gr-modal-box" style="background:{{ card_bg_color }}; color:{{ text_color }};">
            <button class="gr-modal-close">&times;</button>
            <p id="gr-modal-text"></p>
        </div>
    </div>

    <script>
        $(document).ready(function () {

            {% if enable_slider %}
            function grGetPerView() {
                if ($(window).width() < 768) return 1;
                if ($(window).width() < 992) return 2;
                return {{ per_row }};
            }

            $('.gr-swiper').swiper({
                mode: 'horizontal',
                slidesPerView: grGetPerView(),
                spaceBetween: 24,
                autoplay: 4000,
                autoplayDisableOnInteraction: false,
                loop: true,
                watchOverflow: true,
                breakpoints: {
                    0: {
                        slidesPerView: 1,
                        spaceBetween: 16
                    },
                    768: {
                        slidesPerView: 2,
                        spaceBetween: 20
                    },
                    992: {
                        slidesPerView: 3,
                        spaceBetween: 24
                    }
                }
            });
            {% endif %}

            $(document).on('click', '.gr-read-more', function (e) {
                e.preventDefault();
                $('#gr-modal-text').text($(this).data('full'));
                $('#gr-modal').addClass('gr-modal--open');
            });

            $(document).on('click', '.gr-modal-close, .gr-modal-overlay', function () {
                $('#gr-modal').removeClass('gr-modal--open');
            });

        });
    </script>
{% endif %}